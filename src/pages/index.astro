---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Experience from '../components/Experience.astro';
import Projects from '../components/Projects.astro';
import Footer from '../components/Footer.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
---

<BaseLayout>
  <a
    href="#main"
    class="fixed left-4 top-4 z-50 -translate-y-[200%] rounded-sm bg-accent px-4 py-2 text-sm font-medium text-surface transition-transform focus:translate-y-0 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
  >
    Skip to content
  </a>

  <header class="mx-auto flex w-full max-w-6xl items-center justify-between px-6 py-6">
    <a
      href="#top"
      class="font-display text-sm font-semibold tracking-tight text-ink focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
    >
      BP
    </a>
    <div class="flex items-center gap-4">
      <nav aria-label="Primary">
        <ul class="flex items-center gap-6 text-sm text-ink-muted">
          <li>
            <a href="#experience" class="transition-colors hover:text-ink focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent">
              Experience
            </a>
          </li>
          <li>
            <a href="#projects" class="transition-colors hover:text-ink focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent">
              Projects
            </a>
          </li>
          <li>
            <a href="#contact" class="transition-colors hover:text-ink focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent">
              Contact
            </a>
          </li>
        </ul>
      </nav>
      <ThemeToggle />
    </div>
  </header>

  <main id="main">
    <Hero />
    <Experience />
    <Projects />
    <Footer />
  </main>
</BaseLayout>
