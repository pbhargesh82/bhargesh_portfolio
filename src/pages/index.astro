---
import BaseLayout from '../layouts/BaseLayout.astro';
import projectPlaceholders from '../content/project-placeholders.json';
import projects from '../content/projects.json';
import experience from '../content/experience.json';
import socials from '../content/socials.json';
import stack from '../content/stack.json';
import profile from '../content/profile.json';

const github = socials.find((s) => s.name === 'GitHub');
const linkedin = socials.find((s) => s.name === 'LinkedIn');
const dailyDev = socials.find((s) => s.name === 'Daily Dev');
const whatsapp = socials.find((s) => s.name === 'WhatsApp');
const resume = socials.find((s) => s.name === 'Resume');
const year = new Date().getFullYear();

/** Honest counts from profile data — not vanity KPIs */
const stats = [
  { value: profile.yearsExperience, label: 'YEARS_EXP', accent: true },
  { value: String(experience.length).padStart(2, '0'), label: 'ROLES_LOGGED', accent: false },
  { value: String(projects.length).padStart(2, '0'), label: 'PERSONAL_BUILDS', accent: false },
  {
    value: String(stack.frontend.length + stack.backend.length).padStart(2, '0'),
    label: 'STACK_TOOLS',
    accent: true,
  },
];

const shout = (text: string) => text.toUpperCase();
const slug = (text: string) =>
  text
    .replace(/[^a-zA-Z0-9]+/g, '_')
    .replace(/^_|_$/g, '')
    .toUpperCase();
---

<BaseLayout title={profile.pageTitle} description={profile.pageDescription}>
  <!-- Header -->
  <header class="sticky top-0 z-50 bg-surface border-b-heavy border-black">
    <nav class="max-w-full mx-auto flex justify-between items-center h-20 px-6">
      <a class="text-2xl font-extrabold tracking-tighter uppercase" href="#">BHARGESH.LAB</a>
      <div class="hidden md:flex items-center space-x-1">
        <a
          class="px-4 py-2 hover:bg-accent border-l-4 border-black font-bold uppercase transition-colors"
          href="#about">ABOUT</a
        >
        <a
          class="px-4 py-2 hover:bg-accent border-l-4 border-black font-bold uppercase transition-colors"
          href="#projects">WORK</a
        >
        <a
          class="px-4 py-2 hover:bg-accent border-l-4 border-black font-bold uppercase transition-colors"
          href="#experience">LOGS</a
        >
        <a
          class="px-6 py-2 bg-accent border-l-4 border-black font-extrabold uppercase hover:translate-y-[-2px] transition-transform"
          href={resume?.url ?? '#'}
          download={resume?.download}>RESUME.PDF</a
        >
      </div>
      <button class="md:hidden" type="button" aria-label="Menu">
        <span class="material-symbols-outlined text-4xl">menu</span>
      </button>
    </nav>
  </header>

  <main>
    <!-- Hero Section -->
    <section
      class="relative min-h-screen overflow-x-hidden overflow-y-visible bg-white pt-16 md:pt-20"
      id="hero"
    >
      <div class="absolute inset-0 glitch-bg opacity-50 pointer-events-none"></div>
      <div
        class="container relative mx-auto grid gap-0 overflow-visible px-6 py-8 md:grid-cols-12 md:py-12 lg:py-16"
      >
        <div class="z-10 md:col-span-8">
          <div
            class="bg-accent inline-block px-4 py-1 brutal-border mb-6 font-bold uppercase tracking-widest"
          >
            {shout(profile.heroEyebrow)}
          </div>
          <h1 class="text-6xl md:text-9xl font-black uppercase leading-none mb-8 break-words">
            SHIPPING CODE THAT <span class="bg-black text-white px-4">WORKS.</span>
          </h1>
          <p
            class="text-xl md:text-2xl font-bold max-w-2xl mb-12 border-l-brutal border-black pl-6"
          >
            {shout(profile.heroBio)}
          </p>
          <div class="flex flex-wrap gap-6">
            <a
              class="bg-black text-white px-10 py-5 text-xl font-black brutal-shadow-yellow hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all uppercase"
              href="#projects">GET THE STACK</a
            >
            <a
              class="bg-white border-brutal border-black px-10 py-5 text-xl font-black brutal-shadow hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all uppercase"
              href="#contact">WAKE ME UP</a
            >
          </div>
        </div>
        <div class="relative hidden overflow-visible md:col-span-4 md:block md:min-h-[32rem] md:pt-12">
          <div
            class="absolute top-12 right-0 z-0 h-full w-[95%] -rotate-3 bg-accent brutal-border"
            aria-hidden="true"
          >
          </div>
          <figure
            class="relative top-24 z-10 rotate-3 overflow-hidden border-heavy border-black bg-white p-6 brutal-shadow"
            aria-label={`Portfolio status: ${profile.heroCard.status}, ${profile.heroCard.focus}, ${profile.heroCard.availability}`}
          >
            <div
              class="flex aspect-4/3 w-full flex-col justify-between bg-black p-4 font-mono text-xs font-bold leading-relaxed"
              aria-hidden="true"
            >
              <div class="space-y-2 border border-accent p-3 text-accent">
                <p>&gt; INIT PORTFOLIO.V2</p>
                <p>&gt; SCOPE: END_TO_END</p>
                <p>&gt; DELIVERY: CLIENT_FEATURES</p>
                <p class="text-white">&gt; ACCEPTING_WORK_</p>
              </div>
              <div class="grid grid-cols-4 gap-1 pt-3">
                {
                  Array.from({ length: 8 }).map(() => (
                    <div class="h-3 bg-accent" />
                  ))
                }
              </div>
            </div>
            <figcaption class="mt-4 font-mono text-sm leading-tight uppercase font-bold">
              SITE: {slug(profile.heroCard.site)}<br />
              STATUS: {slug(profile.heroCard.status)}<br />
              FOCUS: {slug(profile.heroCard.focus)}<br />
              OPEN: {slug(profile.heroCard.availability)}
            </figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- Marquee -->
    <div
      class="bg-black text-accent py-4 border-b-heavy border-black overflow-hidden select-none"
      aria-label="Highlights"
    >
      <div class="marquee">
        <div class="marquee-track">
          {
            [false, true].map((hidden) => (
              <div class="marquee-group" aria-hidden={hidden}>
                {profile.marquee.map((phrase, index) => (
                  <>
                    {index > 0 && <span class="marquee-sep" aria-hidden="true">//</span>}
                    <span class="marquee-item">{shout(phrase)}</span>
                  </>
                ))}
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- About Section -->
    <section class="py-24 bg-white relative" id="about">
      <div class="container mx-auto px-6">
        <div class="grid lg:grid-cols-12 gap-12 items-start">
          <div class="lg:col-span-5">
            <h2 class="text-5xl md:text-7xl font-black uppercase mb-12 leading-tight">
              THE <span class="bg-accent px-2">MANIFESTO</span>
            </h2>
            <div class="space-y-8 text-xl font-bold leading-relaxed">
              <p>{shout(profile.manifesto[0])}</p>
              <p class="border-l-brutal border-black pl-6">{shout(profile.manifesto[1])}</p>
              <p>{shout(profile.manifesto[2])}</p>
            </div>
          </div>
          <div class="lg:col-span-7 grid grid-cols-2 gap-6">
            {
              stats.map((stat) => (
                <div
                  class:list={[
                    'p-8 border-brutal border-black brutal-shadow-hover transition-all',
                    stat.accent ? 'bg-accent' : 'bg-white',
                  ]}
                >
                  <div class="text-7xl font-black mb-2">{stat.value}</div>
                  <div class="text-xl font-black uppercase underline">{stat.label}</div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Projects Section -->
    <section class="py-24 bg-white" id="projects">
      <div class="container mx-auto px-6">
        <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
          <div>
            <h2 class="text-5xl md:text-8xl font-black uppercase leading-none">THE_VAULT</h2>
            <p class="text-xl font-bold mt-4 uppercase">{shout(profile.projectsIntro)}</p>
          </div>
          <a
            class="group flex items-center gap-4 bg-accent border-brutal border-black px-8 py-4 font-black uppercase hover:bg-black hover:text-white transition-all"
            href={github?.url ?? '#'}
            target="_blank"
            rel="noopener noreferrer">
            OPEN_REPOS.SH
            <span class="material-symbols-outlined group-hover:rotate-45 transition-transform"
              >arrow_forward</span
            >
          </a>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-0 border-t-brutal border-l-brutal border-black">
          {
            projectPlaceholders.map((project, index) => (
              <div class="group border-r-brutal border-b-brutal border-black p-0 relative overflow-hidden bg-white hover:bg-accent transition-colors">
                <div class="h-64 border-b-brutal border-black grayscale contrast-125 overflow-hidden">
                  <img
                    class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-500"
                    src={project.thumbnail}
                    alt={project.thumbnailAlt}
                    width={640}
                    height={480}
                    loading={index === 0 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                </div>
                <div class="p-8">
                  <div class="text-sm font-black uppercase mb-2">{shout(project.tag)}</div>
                  <h3 class="text-3xl font-black uppercase mb-4">{slug(project.name)}</h3>
                  <p class="text-lg font-bold mb-8">{shout(project.description)}</p>
                  <div class="flex items-center justify-between border-t-2 border-black pt-6">
                    <span class="font-black uppercase">{project.stack}</span>
                    <span class="material-symbols-outlined text-4xl">arrow_outward</span>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Experience Section -->
    <section class="py-24 bg-white" id="experience">
      <div class="container mx-auto px-6">
        <h2
          class="text-5xl md:text-8xl font-black uppercase mb-20 border-b-heavy border-black pb-8"
        >
          CAREER_LOGS
        </h2>
        <div class="space-y-0">
          {
            experience.map((job) => (
              <div class="group grid md:grid-cols-12 gap-0 border-b-brutal border-black hover:bg-black hover:text-white transition-colors py-12 px-4 items-center">
                <div class="md:col-span-3 text-2xl font-black">{shout(job.period)}</div>
                <div class="md:col-span-6">
                  <h3 class="text-4xl font-black uppercase mb-2">{slug(job.title)}</h3>
                  <div class="text-xl font-bold uppercase text-accent group-hover:text-accent">
                    {slug(job.company)}
                  </div>
                </div>
                <div class="md:col-span-3 text-right">
                  <span class="text-lg font-bold opacity-70">{shout(job.type)}</span>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="py-24 bg-accent" id="contact">
      <div class="container mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-16 items-start">
          <div class="lg:sticky lg:top-32">
            <h2 class="text-6xl md:text-9xl font-black uppercase leading-none mb-12">SEND_IT.</h2>
            <p class="text-2xl font-black mb-12">
              {shout(profile.contactBody)}
            </p>
            <div class="space-y-8">
              <div class="flex items-center gap-6">
                <div
                  class="w-16 h-16 border-brutal border-black flex items-center justify-center bg-white"
                >
                  <span class="material-symbols-outlined text-4xl">mail</span>
                </div>
                <div>
                  <div class="text-sm font-black uppercase opacity-60">COMMS_LINK</div>
                  <a
                    class="text-2xl font-black underline hover:bg-black hover:text-white"
                    href={`mailto:${profile.email}`}>{shout(profile.email)}</a
                  >
                </div>
              </div>
              <div class="flex items-center gap-6">
                <div
                  class="w-16 h-16 border-brutal border-black flex items-center justify-center bg-white"
                >
                  <span class="material-symbols-outlined text-4xl">location_on</span>
                </div>
                <div>
                  <div class="text-sm font-black uppercase opacity-60">COORD_LOC</div>
                  <span class="text-2xl font-black">{shout(profile.location)}</span>
                </div>
              </div>
            </div>
          </div>
          <form class="bg-white border-heavy border-black p-10 brutal-shadow space-y-8">
            <div class="space-y-4">
              <label class="block text-xl font-black uppercase">NAME_INPUT</label>
              <input
                class="w-full p-4 border-brutal border-black bg-white focus:bg-accent focus:outline-none text-xl font-bold uppercase placeholder:text-black/30"
                placeholder="IDENTIFY YOURSELF"
                type="text"
              />
            </div>
            <div class="space-y-4">
              <label class="block text-xl font-black uppercase">EMAIL_INPUT</label>
              <input
                class="w-full p-4 border-brutal border-black bg-white focus:bg-accent focus:outline-none text-xl font-bold uppercase placeholder:text-black/30"
                placeholder="REPLY_TO@DOMAIN.COM"
                type="email"
              />
            </div>
            <div class="space-y-4">
              <label class="block text-xl font-black uppercase">MESSAGE_PAYLOAD</label>
              <textarea
                class="w-full p-4 border-brutal border-black bg-white focus:bg-accent focus:outline-none text-xl font-bold uppercase placeholder:text-black/30"
                placeholder="DESCRIBE THE MISSION"
                rows="6"></textarea>
            </div>
            <button
              class="w-full bg-black text-white py-6 text-2xl font-black uppercase hover:bg-accent hover:text-black transition-colors brutal-shadow-yellow active:translate-x-1 active:translate-y-1 active:shadow-none"
              type="submit">EXECUTE_SEND</button
            >
          </form>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="bg-black text-white py-12">
    <div class="container mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-8">
      <div class="text-xl font-black uppercase">
        © {year} BHARGESH.LAB // [BUILT_WITH_BRUTALITY]
      </div>
      <div class="flex gap-12 text-lg font-black uppercase">
        <a
          class="hover:text-accent underline decoration-4 underline-offset-4"
          href={github?.url ?? '#'}
          target="_blank"
          rel="noopener noreferrer">GITHUB</a
        >
        <a
          class="hover:text-accent underline decoration-4 underline-offset-4"
          href={linkedin?.url ?? '#'}
          target="_blank"
          rel="noopener noreferrer">LINKEDIN</a
        >
        <a
          class="hover:text-accent underline decoration-4 underline-offset-4"
          href={dailyDev?.url ?? '#'}
          target="_blank"
          rel="noopener noreferrer">DAILY DEV</a
        >
        <a
          class="hover:text-accent underline decoration-4 underline-offset-4"
          href={whatsapp?.url ?? '#'}
          target="_blank"
          rel="noopener noreferrer">WHATSAPP</a
        >
      </div>
    </div>
  </footer>

  <script is:inline>
    const reveal = () => {
      const items = document.querySelectorAll('section');
      items.forEach((item) => {
        const rect = item.getBoundingClientRect();
        if (rect.top < window.innerHeight - 100) {
          item.style.opacity = '1';
          item.style.transform = 'translateY(0)';
        }
      });
    };

    window.addEventListener('scroll', reveal);
    window.addEventListener('load', () => {
      document.querySelectorAll('section').forEach((s) => {
        s.style.transition = 'all 0.4s cubic-bezier(0.17, 0.67, 0.83, 0.67)';
      });
      reveal();
    });
  </script>
</BaseLayout>
