---
import MaterialIcon from './MaterialIcon.astro';

const focusRing =
  'focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent';
---

<button
  type="button"
  id="theme-toggle"
  class:list={[
    'flex size-9 items-center justify-center rounded-sm text-ink-muted transition-colors',
    'hover:text-accent',
    focusRing,
  ]}
  aria-label="Switch color theme"
>
  <span class="inline-flex dark:hidden" aria-hidden="true">
    <MaterialIcon name="dark_mode" size={20} />
  </span>
  <span class="hidden dark:inline-flex" aria-hidden="true">
    <MaterialIcon name="light_mode" size={20} />
  </span>
</button>

<script>
  import { applyTheme, getTheme, initThemeToggle } from '../scripts/theme';

  applyTheme(getTheme());
  initThemeToggle(document.getElementById('theme-toggle'));
</script>
