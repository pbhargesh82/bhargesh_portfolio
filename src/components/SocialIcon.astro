---
import BrandIcon from './BrandIcon.astro';
import MaterialIcon from './MaterialIcon.astro';

interface Props {
  icon: string;
  iconSet?: 'simpleicons' | 'material';
  size?: number;
  class?: string;
}

const { icon, iconSet = 'simpleicons', size = 20, class: className } = Astro.props;
---

{
  iconSet === 'material' ? (
    <MaterialIcon name={icon} size={size} class={className} />
  ) : (
    <BrandIcon slug={icon} size={size} class={className} />
  )
}
