---
import socials from '../content/socials.json';
import SocialIcon from './SocialIcon.astro';
import MaterialIcon from './MaterialIcon.astro';

const email = 'pbhargesh82@gmail.com';
const year = new Date().getFullYear();

const focusRing =
  'focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink';
---

<section id="contact" class="bg-accent py-20 md:py-24">
  <div class="mx-auto w-full max-w-7xl px-6">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
      <div class="lg:sticky lg:top-28 lg:self-start">
        <h2
          class="mb-8 text-[clamp(2.5rem,8vw,5rem)] font-extrabold uppercase leading-[0.95] tracking-[-0.03em]"
        >
          Say hello
        </h2>
        <p class="mb-10 max-w-lg text-xl font-bold leading-relaxed">
          Open to contract and freelance projects. Based in Surat, happy to work remote. Email is
          the fastest way to reach me.
        </p>

        <div class="space-y-6">
          <div class="flex items-center gap-5">
            <div
              class="flex size-14 shrink-0 items-center justify-center border-4 border-ink bg-paper"
              aria-hidden="true"
            >
              <MaterialIcon name="mail" size={28} />
            </div>
            <div>
              <p class="text-xs font-extrabold uppercase tracking-widest text-ink-muted">Email</p>
              <a
                href={`mailto:${email}`}
                class:list={['text-xl font-extrabold uppercase underline decoration-4 underline-offset-4 hover:bg-ink hover:text-paper hover:no-underline', focusRing]}
              >
                {email}
              </a>
            </div>
          </div>
          <div class="flex items-center gap-5">
            <div
              class="flex size-14 shrink-0 items-center justify-center border-4 border-ink bg-paper"
              aria-hidden="true"
            >
              <MaterialIcon name="location_on" size={28} />
            </div>
            <div>
              <p class="text-xs font-extrabold uppercase tracking-widest text-ink-muted">Location</p>
              <p class="text-xl font-extrabold uppercase">Surat · Remote</p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-paper p-8 brutal-border-heavy brutal-shadow sm:p-10">
        <p class="mb-6 text-sm font-bold uppercase tracking-wide text-ink-subtle">
          Or find me elsewhere
        </p>
        <ul class="grid gap-3 sm:grid-cols-2">
          {
            socials.map((social) => (
              <li>
                <a
                  href={social.url}
                  target={social.name === 'Resume' ? undefined : '_blank'}
                  rel={social.name === 'Resume' ? undefined : 'noopener noreferrer'}
                  download={social.download}
                  class:list={[
                    'flex items-center gap-3 border-4 border-ink px-4 py-3 text-sm font-extrabold uppercase transition-colors hover:bg-accent',
                    focusRing,
                  ]}
                >
                  <SocialIcon icon={social.icon} iconSet={social.iconSet} size={18} />
                  {social.name}
                </a>
              </li>
            ))
          }
        </ul>
        <a
          href={`mailto:${email}`}
          class:list={[
            'mt-8 flex w-full min-h-14 items-center justify-center bg-ink px-6 py-4 text-lg font-extrabold uppercase text-paper brutal-shadow-accent transition-[transform,box-shadow] hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-none active:translate-x-1 active:translate-y-1',
            focusRing,
          ]}
        >
          Send email
        </a>
      </div>
    </div>
  </div>
</section>

<footer class="border-t-8 border-ink bg-ink py-10 text-paper">
  <div class="mx-auto flex w-full max-w-7xl flex-col items-center justify-between gap-6 px-6 sm:flex-row">
    <p class="text-sm font-extrabold uppercase tracking-tight">
      © {year} Bhargesh Patel
    </p>
    <nav aria-label="Footer">
      <ul class="flex flex-wrap justify-center gap-6 text-sm font-extrabold uppercase">
        {
          socials
            .filter((s) => s.name !== 'Resume')
            .map((social) => (
              <li>
                <a
                  href={social.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class:list={['underline decoration-4 underline-offset-4 hover:text-accent', focusRing]}
                >
                  {social.name}
                </a>
              </li>
            ))
        }
      </ul>
    </nav>
    <a href="#top" class:list={['text-sm font-bold uppercase hover:text-accent', focusRing]}>
      Back to top
    </a>
  </div>
</footer>
