---
import { brandIconUrl } from '../lib/icons';

interface Props {
  slug: string;
  size?: number;
  class?: string;
}

const { slug, size = 20, class: className } = Astro.props;
const src = brandIconUrl(slug);
---

<span
  class:list={['brand-icon inline-block shrink-0 bg-ink-muted', className]}
  style={`width: ${size}px; height: ${size}px; mask: url('${src}') center / contain no-repeat; -webkit-mask: url('${src}') center / contain no-repeat;`}
  aria-hidden="true"
/>
