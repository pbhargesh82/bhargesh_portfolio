---
import experience from '../content/experience.json';
---

<section id="experience" class="section-rule bg-paper py-20 md:py-24">
  <div class="mx-auto w-full max-w-7xl px-6">
    <header class="mb-12 border-b-8 border-ink pb-8 md:mb-16">
      <h2 class="text-[clamp(2rem,6vw,4rem)] font-extrabold uppercase leading-none tracking-[-0.03em]">
        Career logs
      </h2>
      <p class="mt-4 max-w-2xl text-lg font-semibold leading-relaxed text-ink-muted">
        Five years from on-site frontend work to end-to-end product builds — now shipping full
        features, not just UI.
      </p>
    </header>

    <ol class="divide-y-4 divide-ink border-t-4 border-ink">
      {
        experience.map((job) => (
          <li>
            <article
              class:list={[
                'group grid items-center gap-4 px-2 py-10 transition-colors hover:bg-ink hover:text-paper md:grid-cols-12 md:gap-6 md:px-4',
                job.current && 'bg-accent/15',
              ]}
            >
              <div class="text-lg font-extrabold tabular-nums md:col-span-3 md:text-xl">
                <time datetime={job.period.replace(' – ', '/').replace('Present', '')}>
                  {job.period}
                </time>
                <p class="mt-1 text-sm font-semibold text-ink-subtle group-hover:text-paper/70">
                  {job.duration}
                </p>
              </div>
              <div class="md:col-span-6">
                <h3 class="text-2xl font-extrabold uppercase tracking-tight md:text-3xl">
                  {job.title}
                </h3>
                <p class="mt-1 text-lg font-bold uppercase text-ink-muted group-hover:text-accent">
                  {job.company}
                </p>
                {job.summary && (
                  <p class="mt-3 max-w-prose text-base font-medium leading-relaxed text-ink-muted group-hover:text-paper/85">
                    {job.summary}
                  </p>
                )}
              </div>
              <div class="md:col-span-3 md:text-right">
                <span class="text-sm font-bold uppercase text-ink-subtle group-hover:text-paper/70">
                  {job.type}
                </span>
                {job.current && (
                  <p class="mt-2 text-xs font-extrabold uppercase text-ink group-hover:text-accent">
                    Current role
                  </p>
                )}
              </div>
            </article>
          </li>
        ))
      }
    </ol>
  </div>
</section>
