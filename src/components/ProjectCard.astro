---
import MaterialIcon from './MaterialIcon.astro';

interface Props {
  index: number;
  name: string;
  description: string;
  url: string;
  uiRepoUrl: string;
  apiRepoUrl?: string;
  stack: string[];
  thumbnail?: string;
  thumbnailAlt?: string;
}

const { index, name, description, url, uiRepoUrl, stack, thumbnail, thumbnailAlt } = Astro.props;

const focusRing =
  'focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink';

const paddedIndex = String(index).padStart(2, '0');
---

<article
  class="group relative overflow-hidden border-r-4 border-b-4 border-ink bg-paper transition-colors hover:bg-accent"
>
  {
    thumbnail && (
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class:list={['block h-56 overflow-hidden border-b-4 border-ink sm:h-64', focusRing]}
      >
        <img
          src={thumbnail}
          alt={thumbnailAlt ?? `${name} screenshot`}
          width={800}
          height={500}
          class="size-full object-cover object-top contrast-125 grayscale transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-105 motion-reduce:transform-none"
          loading="lazy"
          decoding="async"
        />
      </a>
    )
  }

  <div class="p-6 sm:p-8">
    <p class="mb-2 text-xs font-extrabold uppercase tracking-widest text-ink-subtle">
      Case {paddedIndex}
    </p>
    <h3 class="mb-4 text-2xl font-extrabold uppercase tracking-tight sm:text-3xl">{name}</h3>
    <p class="mb-6 text-base font-semibold leading-relaxed text-ink-muted">{description}</p>

    <ul class="mb-6 flex flex-wrap gap-2" aria-label={`${name} tech stack`}>
      {
        stack.map((tech) => (
          <li>
            <span class="border-2 border-ink bg-paper px-2.5 py-1 text-xs font-bold uppercase group-hover:bg-paper">
              {tech}
            </span>
          </li>
        ))
      }
    </ul>

    <footer class="flex items-center justify-between border-t-2 border-ink pt-5">
      <div class="flex flex-wrap gap-4 text-sm font-extrabold uppercase">
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class:list={['hover:underline', focusRing]}
        >
          Live
        </a>
        <a
          href={uiRepoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class:list={['text-ink-muted hover:underline', focusRing]}
        >
          Code
        </a>
      </div>
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class:list={[focusRing]}
        aria-label={`Open ${name}`}
      >
        <MaterialIcon name="arrow_outward" size={28} />
      </a>
    </footer>
  </div>
</article>
